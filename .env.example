# Used only by the optional scheduler wrapper (see README §Scheduler integration),
# NOT by the skill itself. Copy to `.env` and fill in.

# Discord webhook for push notifications (Discord channel → Integrations → Webhook → New)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXX/YYYYY

# Optional: override default output directory
# DIGEST_OUTPUT_DIR=./digests
